# Client-side (Vite): đặt trong .env.local — sau khi sửa phải khởi động lại `npm run dev`.
VITE_GROQ_API_KEY="YOUR_GROQ_API_KEY"

# Tuỳ chọn model Groq (mặc định llama-3.3-70b-versatile)
# VITE_GROQ_MODEL="llama-3.3-70b-versatile"

# Giới hạn ký tự gửi lên Groq (1500–15000). Mặc định ~4000 để tránh 413/TPM free tier.
# VITE_GROQ_MAX_INPUT_CHARS="4000"

# URL công khai của app (OAuth, callback, chia sẻ). Trên CodeSandbox thường không cần — Vite đã gắn từ CODESANDBOX_HOST.
# VITE_PUBLIC_APP_URL="https://your-domain.example"

# Legacy / AI Studio (server-side nếu có)
# APP_URL="MY_APP_URL"
